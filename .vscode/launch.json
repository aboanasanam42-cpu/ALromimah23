{
    // استخدم IntelliSense لمعرفة المزيد عن السمات الممكنة.
    // أشر لعرض وصف السمات الموجودة.
    // لمزيد من المعلومات، قم بزيارة: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        


        {
            "command": "npm start",
            "name": "Run npm start",
            "request": "launch",
            "type": "node-terminal"
        },
        {
            "address": "TCP/IP address of process to be debugged",
            "localRoot": "${workspaceFolder}",
            "name": "Attach to Remote",
            "port": 9229,
            "remoteRoot": "Absolute path to the remote directory containing the program",
            "request": "attach",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },


        {
            "type": "chrome",
            "request": "launch",
            "name": "تشغيل كروم باستخدام المضيف المحلي",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}